{
  "name": "@kinesisjs/openlayers",
  "version": "0.1.0",
  "description": "OpenLayers map adapter for Kinesis.js — feature lifecycle and styling",
  "license": "MIT",
  "author": "Muzaffer Aşkar",
  "homepage": "https://github.com/kinesisjs/kinesis.js/tree/main/packages/openlayers#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kinesisjs/kinesis.js.git",
    "directory": "packages/openlayers"
  },
  "bugs": {
    "url": "https://github.com/kinesisjs/kinesis.js/issues"
  },
  "keywords": [
    "fleet-tracking",
    "vehicle-tracking",
    "interpolation",
    "openlayers",
    "ol",
    "maps",
    "gis",
    "real-time",
    "kinesisjs"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --root ../..",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kinesisjs/core": "workspace:*"
  },
  "peerDependencies": {
    "ol": ">=8.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
