{
  "name": "@kinesisjs/angular",
  "version": "0.1.2",
  "description": "Angular Signals / RxJS wrapper for Kinesis.js",
  "license": "MIT",
  "author": "Muzaffer Aşkar",
  "homepage": "https://github.com/kinesisjs/kinesis.js/tree/main/packages/angular#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kinesisjs/kinesis.js.git",
    "directory": "packages/angular"
  },
  "bugs": {
    "url": "https://github.com/kinesisjs/kinesis.js/issues"
  },
  "keywords": [
    "angular",
    "signals",
    "rxjs",
    "fleet-tracking",
    "vehicle-tracking",
    "interpolation",
    "openlayers",
    "real-time",
    "maps",
    "kinesisjs"
  ],
  "main": "./dist/fesm2022/kinesisjs-angular.mjs",
  "module": "./dist/fesm2022/kinesisjs-angular.mjs",
  "typings": "./dist/index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/kinesisjs-angular.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "dev": "ng-packagr -p ng-package.json -c tsconfig.lib.json --watch",
    "test": "vitest run --root ../..",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kinesisjs/core": "workspace:*",
    "@kinesisjs/openlayers": "workspace:*",
    "tslib": "^2.6.0"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "ol": ">=8.0.0",
    "rxjs": ">=7.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
