# Dependencies
node_modules/

# Build output
dist/
build/
out/
*.tsbuildinfo

# Test
coverage/
.vitest/

# Tool caches
.nx/
.turbo/
.vite/
.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / IDE / AI workspace data — personal to each contributor's machine,
# never tracked on public repositories.
.idea/
.vscode/
.claude/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Env
.env
.env.local
.env.*.local

# Changesets
.changeset/.cache/

# Internal markdown documents — only README.md, CHANGELOG.md and CLAUDE.md may be
# committed at the repository root. Per-package README/CHANGELOG and the public docs
# site under documents/ remain tracked because npm tarballs and the docs site rely
# on them. Internal design notes live under documents/design/ (gitignored).
/*.md
!/README.md
!/CHANGELOG.md
!/CLAUDE.md
documents/design/
